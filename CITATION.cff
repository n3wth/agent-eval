    family-names: Newth
    given-names: Oliver
repository-code: "https://github.com/n3wth/agent-eval"
url: "https://github.com/n3wth/agent-eval"
license: MIT
keywords:
  - AI agents
  - evaluation
  - LLM
  - memory
  - trust calibration
  - human-AI collaboration
